# =======================================================================
# Server-side (private — never exposed to the browser)
# =======================================================================

# Required: Gemini API key used by the /api/scan-odometer proxy endpoint.
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Gemini model name. Defaults to "gemini-3-flash-preview" if unset.
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: HTTP port the Express server listens on. Coolify will set this.
# PORT=3000

# =======================================================================
# Client-side (VITE_ prefix — embedded in the build, safe to be public
# because Firestore Rules + Auth Authorized Domains enforce security)
# =======================================================================

# Required: Firebase Web App config from Firebase console
# (Project settings → General → Your apps → Web app → Config).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Optional: Only set if you use a non-default Firestore database.
# Leave empty to use the default "(default)" database (recommended).
# VITE_FIREBASE_DATABASE_ID=
